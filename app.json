{
  "expo": {
    "name": "NoteVault",
    "slug": "NoteVault",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F1F5F9"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.saipr.notevault"
    },
    "android": {
      "package": "com.saipr.notevault",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.USE_BIOMETRIC"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sqlite",
      "expo-audio",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#4F46E5",
          "androidMode": "default"
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "NoteVault uses Face ID to unlock your vault."
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "NoteVault needs camera access to take photos for your notes.",
          "photosPermission": "NoteVault needs photo library access to attach images to your notes."
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./node_modules/expo/node_modules/@expo/vector-icons/build/vendor/react-native-vector-icons/Fonts/Feather.ttf",
            "./node_modules/expo/node_modules/@expo/vector-icons/build/vendor/react-native-vector-icons/Fonts/MaterialIcons.ttf",
            "./node_modules/expo/node_modules/@expo/vector-icons/build/vendor/react-native-vector-icons/Fonts/Ionicons.ttf"
          ]
        }
      ],
      "expo-asset",
      [
        "expo-camera",
        {
          "cameraPermission": "NoteVault uses the camera to silently photograph intruders on failed PIN attempts."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "82184797-2723-4b76-9ec3-8f2b3cd42a6c"
      }
    },
    "owner": "saipraneethboni"
  }
}
