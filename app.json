{
  "expo": {
    "name": "NoteVault - Private Notes with Lock",
    "slug": "NoteVault",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#F1F5F9"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.saipr.notevault"
    },
    "android": {
      "package": "com.saipr.notevault",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sqlite",
      "expo-audio",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "NoteVault uses Face ID to unlock your vault."
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "NoteVault needs camera access to take photos for your notes.",
          "photosPermission": "NoteVault needs photo library access to attach images to your notes."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "82184797-2723-4b76-9ec3-8f2b3cd42a6c"
      }
    },
    "owner": "saipraneethboni"
  }
}
